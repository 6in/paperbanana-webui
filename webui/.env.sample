# =========================
# PaperBanana WebUI sample env
# Copy this file and replace placeholder values.
# =========================

# --- Shared base path ---
WEBUI_BASE_PATH=/paper-banana-webui

# --- Auth toggle ---
AUTH_REQUIRED=true

# --- Google OAuth ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# --- Authorization policy ---
# Comma-separated domains allowed to sign in.
AUTH_ALLOWED_DOMAINS=example.co.jp,group.example.co.jp

# YAML file path for allow/deny email lists.
# If relative, it is resolved from webui/ directory.
AUTH_EMAIL_RULES_FILE=auth/email-rules.sample.yaml

# --- Auth cookie ---
AUTH_COOKIE_NAME=email
AUTH_COOKIE_MAX_AGE_SECONDS=604800

# --- CORS ---
# Comma-separated origins. Keep frontend origin(s) only.
CORS_ALLOW_ORIGINS=https://your-internal-host.example.co.jp,http://localhost:54312

# --- Frontend (Vite) ---
VITE_BASE_PATH=/paper-banana-webui/
VITE_API_PREFIX=/paper-banana-webui

# Optional. Leave empty for same-origin deployment.
VITE_BACKEND_ORIGIN=https://your-internal-host.example.co.jp
